APP_NAME=quant_msx
APP_ENV=local
LOG_LEVEL=INFO

MSX_BASE_URL=https://api9528mystks.mystonks.org
MSX_SPOT_WS_URL=wss://api9528mystks.mystonks.org/api/v1/spot/ws
MSX_FUTURES_WS_URL=wss://api9528mystks.mystonks.org/api/v1/futures/ws
MSX_API_KEY=
MSX_SECRET_KEY=
MSX_HTTP_TIMEOUT_SECONDS=30
MSX_HTTP_RETRY_ATTEMPTS=2
MSX_HTTP_RETRY_BACKOFF_SECONDS=0.2
MSX_HTTP_MAX_CONNECTIONS=100
MSX_HTTP_MAX_KEEPALIVE_CONNECTIONS=20
MSX_HTTP_REQUESTS_PER_SECOND=0

ACCOUNT_CREDENTIALS_FERNET_KEY=

DATABASE_URL=sqlite:///./data/quant_msx.sqlite3
LIVE_TRADING_ENABLED=false
GRID_DEMO_MODE=true
SCHEDULER_ENABLED=false
SCHEDULER_INITIAL_DELAY_SECONDS=10
SCHEDULER_LOCK_TTL_SECONDS=120
GRID_HEALTH_SYNC_INTERVAL_SECONDS=60
ACCOUNT_BALANCE_SNAPSHOT_INTERVAL_SECONDS=300
